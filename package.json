{
  "name": "tadabor",
  "version": "0.48.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/AbstractThinker0/tadabor.git"
  },
  "bugs": {
    "url": "https://github.com/AbstractThinker0/tadabor/issues"
  },
  "description": "A Quran web application",
  "author": "AbstractThinker0",
  "license": "MIT",
  "scripts": {
    "preinstall": "npm install tadabor-shared@latest --min-release-age=0",
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "theme": "npx @chakra-ui/cli typegen ./src/theme/index.ts",
    "lint": "eslint src --ext ts,tsx --config eslint.config.js --max-warnings 0",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "playwright test",
    "test:integration": "playwright test -c playwright.integration.config.ts",
    "test:ui": "playwright test --ui",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/favicon.svg",
    "preview": "vite preview"
  },
  "type": "module",
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@hcaptcha/react-hcaptcha": "2.0.2",
    "@orpc/client": "^1.14.3",
    "@orpc/contract": "^1.14.3",
    "@orpc/tanstack-query": "^1.14.3",
    "@tanstack/react-query": "^5.90.12",
    "dexie": "4.4.2",
    "i18next": "23.0.1",
    "i18next-browser-languagedetector": "8.2.1",
    "immer": "^11.1.3",
    "next-themes": "0.4.6",
    "quran-tools": "0.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "6.1.1",
    "react-i18next": "13.0.0",
    "react-icons": "5.6.0",
    "react-router": "^8.0.1",
    "tadabor-shared": "^0.0.8",
    "usehooks-ts": "3.1.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.9.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-react": "5.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "17.6.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.49.0",
    "vite": "7.3.2",
    "vite-plugin-pwa": "1.2.0",
    "vite-tsconfig-paths": "6.1.1"
  }
}
